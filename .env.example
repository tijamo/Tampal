# ---------------------------------------------------------------------------
# TamFam PWA environment variables
# Copy to `.env.local` and fill in. Never commit real values.
# ---------------------------------------------------------------------------

# Supabase project (create in the London eu-west-2 region for UK data residency).
# Found under Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Service-role key — SERVER ONLY. Grants full DB access, bypassing RLS.
# Used only for admin GDPR operations (export/erasure, invites). Never expose
# to the browser and never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Public base URL of the deployed app (used for auth email redirect links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Data controller details shown in the privacy notice.
NEXT_PUBLIC_DATA_CONTROLLER_NAME=Tamworth Christadelphian Church
NEXT_PUBLIC_DATA_CONTROLLER_EMAIL=privacy@example.org
